default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight. Bundle ID and scheme are auto-derived per app."
  lane :build_ipa do
    # Fastlane itself runs with Dir.pwd set to this Fastfile's own directory
    # (.../project/fastlane), not the project root (.../project) — confirmed
    # by logging Dir.pwd here. So "ios/" must be resolved one level up.
    project_root = File.expand_path("..", Dir.pwd)

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_CONNECT_KEY_FILEPATH"],
      in_house: false,
    )

    bundle_id = ENV["APP_BUNDLE_ID"]
    scheme    = ENV["XCODE_SCHEME"]

    UI.message("Building bundle ID : #{bundle_id}")
    UI.message("Xcode scheme       : #{scheme}")

    # Bundle ID registration is handled by the CI workflow step before
    # Fastlane runs — no Spaceship token setup here so match's api_key auth
    # is not overridden by a conflicting global Spaceship token.

    create_keychain(
      name: ENV["MATCH_KEYCHAIN_NAME"],
      password: ENV["MATCH_KEYCHAIN_PASSWORD"],
      default_keychain: true,
      unlock: true,
      timeout: 3600,
      lock_when_sleeps: false,
    )

    begin
      # Create the App Store Connect app record if it doesn't exist yet.
      # produce uses Apple ID + app-specific password (Spaceship web auth)
      # because the ASC REST API forbids POST /v1/apps for standard accounts.
      safe_display_name = bundle_id.split('.').last.gsub('-', ' ').split.map(&:capitalize).join(' ')[0, 30]
      sku = bundle_id.gsub('.', '-')[0, 50]
      produce(
        username:       ENV["APPLE_ID"],
        app_identifier: bundle_id,
        app_name:       safe_display_name,
        company_name:   ENV["APPLE_COMPANY_NAME"],
        language:       "English",
        app_version:    "1.0",
        sku:            sku,
        team_id:        ENV["APPLE_TEAM_ID"],
        itc_team_id:    ENV["APPLE_TEAM_ID"],
      )

      # appstore type: no device registration required in the portal.
      # development type was failing with ENTITY_ERROR_RELATIONSHIP_REQUIRED
      # because Apple requires at least one registered device for dev profiles.
      match(
        type: "appstore",
        readonly: false,
        api_key: api_key,
        git_url: ENV["MATCH_GIT_URL"],
        git_basic_authorization: ENV["MATCH_GIT_PAT_B64"],
        app_identifier: bundle_id,
        team_id: ENV["APPLE_TEAM_ID"],
        keychain_name: ENV["MATCH_KEYCHAIN_NAME"],
        keychain_password: ENV["MATCH_KEYCHAIN_PASSWORD"],
      )

      # Resolve the .xcworkspace path — handles app names with spaces safely.
      # Anchored to project_root (captured before any actions ran above) since
      # Dir.pwd is not reliable here.
      UI.message("Resolving workspace from project_root: #{project_root} (current Dir.pwd: #{Dir.pwd})")
      workspace_path = Dir[File.join(project_root, "ios", "**", "*.xcworkspace")]
                          .reject { |p| p.include?("Pods") }.first
      if workspace_path.nil?
        UI.user_error!("No .xcworkspace found in ios/ — did expo prebuild succeed?\nFound: #{Dir[File.join(project_root, 'ios', '**', '*')].inspect}")
      end
      UI.message("Using workspace: #{workspace_path}")

      build_output_dir = File.join(project_root, "build")
      ipa_path = File.join(build_output_dir, "app.ipa")

      # expo prebuild generates the Xcode project with automatic signing but
      # no team set, so gym fails with "requires a development team". Set
      # the team explicitly; signing/profile management itself is then
      # handled non-interactively by xcodebuild via the ASC API key below
      # (-allowProvisioningUpdates + -authenticationKey*), not by match.
      xcodeproj_path = Dir[File.join(project_root, "ios", "*.xcodeproj")].first
      if xcodeproj_path.nil?
        UI.user_error!("No .xcodeproj found in ios/ — did expo prebuild succeed?\nFound: #{Dir[File.join(project_root, 'ios', '**', '*')].inspect}")
      end

      update_code_signing_settings(
        use_automatic_signing: true,
        path: xcodeproj_path,
        team_id: ENV["APPLE_TEAM_ID"],
        bundle_identifier: bundle_id,
      )

      auth_xcargs = "-authenticationKeyPath #{ENV['APP_STORE_CONNECT_KEY_FILEPATH']} " \
                    "-authenticationKeyID #{ENV['APP_STORE_CONNECT_KEY_ID']} " \
                    "-authenticationKeyIssuerID #{ENV['APP_STORE_CONNECT_ISSUER_ID']}"

      gym(
        scheme: scheme,
        workspace: workspace_path,
        export_method: "app-store",
        output_directory: build_output_dir,
        output_name: "app.ipa",
        clean: true,
        xcargs: "-allowProvisioningUpdates #{auth_xcargs}",
        # gym only appends `xcargs` to the archive command — the separate
        # `xcodebuild -exportArchive` step needs its own auth or automatic
        # signing/profile resolution can fail there too.
        export_xcargs: "-allowProvisioningUpdates #{auth_xcargs}",
        export_options: {
          method: "app-store",
          teamID: ENV["APPLE_TEAM_ID"],
          signingStyle: "automatic",
        },
      )

      upload_to_testflight(
        api_key: api_key,
        ipa: ipa_path,
        app_identifier: bundle_id,
        skip_waiting_for_build_processing: true,
        notify_external_testers: false,
      )
    ensure
      delete_keychain(name: ENV["MATCH_KEYCHAIN_NAME"]) rescue nil
    end
  end

  desc "One-time: generate and push certs + profiles to the certificates repo"
  lane :init_match do
    cert_type = (ENV["MATCH_TYPE"] || "appstore").gsub("-", "")

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_CONNECT_KEY_FILEPATH"],
      in_house: false,
    )

    # Revoke all existing certs of this type in the portal and wipe them from
    # the git repo so match can create a fresh certificate without hitting
    # Apple's 2-cert limit. Safe here because init_match is an explicit reset.
    match_nuke(
      type: cert_type,
      api_key: api_key,
      git_url: ENV["MATCH_GIT_URL"],
      git_basic_authorization: ENV["MATCH_GIT_PAT_B64"],
      team_id: ENV["APPLE_TEAM_ID"],
      skip_confirmation: true,
    )

    # Empty array + skip_provisioning_profiles = certificate only.
    # No bundle ID lookup is performed; profiles are created per-app in build_ipa.
    match(
      type: cert_type,
      readonly: false,
      api_key: api_key,
      git_url: ENV["MATCH_GIT_URL"],
      git_basic_authorization: ENV["MATCH_GIT_PAT_B64"],
      app_identifier: [],
      team_id: ENV["APPLE_TEAM_ID"],
      skip_provisioning_profiles: true,
    )
  end
end
