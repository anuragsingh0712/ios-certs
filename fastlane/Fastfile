require 'digest'

default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight. Bundle ID and scheme are auto-derived per app."
  lane :build_ipa do
    # Fastlane itself runs with Dir.pwd set to this Fastfile's own directory
    # (.../project/fastlane), not the project root (.../project) — confirmed
    # by logging Dir.pwd here. So "ios/" must be resolved one level up.
    project_root = File.expand_path("..", Dir.pwd)

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_CONNECT_KEY_FILEPATH"],
      in_house: false,
    )

    bundle_id = ENV["APP_BUNDLE_ID"]
    scheme    = ENV["XCODE_SCHEME"]

    UI.message("Building bundle ID : #{bundle_id}")
    UI.message("Xcode scheme       : #{scheme}")

    # Bundle ID registration is handled by the CI workflow step before
    # Fastlane runs — no Spaceship token setup here so match's api_key auth
    # is not overridden by a conflicting global Spaceship token.

    # Normally a no-op on the GitHub-hosted macos-latest runner this currently
    # runs on (fresh VM per job, no prior keychain). Kept as a cheap guard in
    # case this ever moves to a self-hosted/persistent runner, where a
    # keychain left behind by a previous/crashed run could otherwise collide
    # with create_keychain below.
    delete_keychain(name: ENV["MATCH_KEYCHAIN_NAME"]) if File.exist?(File.expand_path("~/Library/Keychains/#{ENV["MATCH_KEYCHAIN_NAME"]}-db"))

    create_keychain(
      name: ENV["MATCH_KEYCHAIN_NAME"],
      password: ENV["MATCH_KEYCHAIN_PASSWORD"],
      default_keychain: true,
      unlock: true,
      timeout: 3600,
      lock_when_sleeps: false,
    )

    # macOS 15 regression: create_keychain no longer automatically adds the
    # custom keychain to the user's keychain search list, so `security` and
    # `codesign` can't find certs imported into it (manifest as "no local code
    # signing identities found" even though match just installed the cert).
    # Explicitly set the search list to: custom keychain first, then login keychain.
    keychain_path = File.expand_path("~/Library/Keychains/#{ENV["MATCH_KEYCHAIN_NAME"]}-db")
    login_keychain = File.expand_path("~/Library/Keychains/login.keychain-db")
    sh("security list-keychains -d user -s '#{keychain_path}' '#{login_keychain}'")
    sh("security unlock-keychain -p '#{ENV["MATCH_KEYCHAIN_PASSWORD"]}' '#{keychain_path}'")

    begin
      # Look up whether an App Store Connect app record already exists for
      # this bundle ID — e.g. a previous run got this far and created it
      # before failing later in the pipeline. This lookup works with the
      # API key (only POST /v1/apps for *creating* an app is blocked for
      # standard accounts, GET is not), so it never needs Apple ID web auth.
      # Skipping produce when the app already exists also means a re-run of
      # an already-provisioned app no longer depends on a valid Apple ID
      # session/2FA at all.
      # Spaceship::ConnectAPI::App.find can raise (rate limit, invalid key,
      # network error) instead of returning nil. Treat any exception as
      # "app not found" and fall through to produce — if produce also fails,
      # the real error surfaces there with a clearer message.
      existing_app = begin
        Spaceship::ConnectAPI::App.find(bundle_id)
      rescue => spaceship_err
        UI.important("ASC API lookup raised #{spaceship_err.class}: #{spaceship_err.message} — assuming app does not exist yet, falling through to produce.")
        nil
      end

      if existing_app
        UI.message("App Store Connect app already exists for #{bundle_id} (id: #{existing_app.id}) — skipping produce.")
      else
        # produce uses Apple ID + app-specific password (Spaceship web auth)
        # because the ASC REST API forbids POST /v1/apps for standard accounts.
        #
        # App Store *display names* are unique across ALL Apple developer
        # accounts worldwide (unlike bundle IDs, which are effectively
        # namespaced here by the "com.frontendx." prefix) — generic generated
        # names like "Todo App" or "Weather App" routinely collide with an
        # existing app from a different account. Append a short suffix
        # derived from the bundle ID to dodge that, deterministically (not
        # random) so retrying produce for the same bundle ID keeps producing
        # the same name instead of registering a new one each attempt.
        name_suffix = Digest::SHA256.hexdigest(bundle_id)[0, 6]
        base_name = bundle_id.split('.').last.gsub('-', ' ').split.map(&:capitalize).join(' ')[0, 22]
        safe_display_name = "#{base_name} #{name_suffix}"[0, 30]
        sku = bundle_id.gsub('.', '-')[0, 50]
        produce(
          username:       ENV["APPLE_ID"],
          app_identifier: bundle_id,
          app_name:       safe_display_name,
          company_name:   ENV["APPLE_COMPANY_NAME"],
          language:       "English",
          app_version:    "1.0",
          sku:            sku,
          team_id:        ENV["APPLE_TEAM_ID"],
          itc_team_id:    ENV["APPLE_ITC_TEAM_ID"] || ENV["APPLE_TEAM_ID"],
        )
      end

      # appstore type: no device registration required in the portal.
      # development type was failing with ENTITY_ERROR_RELATIONSHIP_REQUIRED
      # because Apple requires at least one registered device for dev profiles.
      match(
        type: "appstore",
        readonly: false,
        api_key: api_key,
        git_url: ENV["MATCH_GIT_URL"],
        git_basic_authorization: ENV["MATCH_GIT_PAT_B64"],
        app_identifier: bundle_id,
        team_id: ENV["APPLE_TEAM_ID"],
        keychain_name: ENV["MATCH_KEYCHAIN_NAME"],
        keychain_password: ENV["MATCH_KEYCHAIN_PASSWORD"],
      )

      # Resolve the .xcworkspace path — handles app names with spaces safely.
      # Anchored to project_root (captured before any actions ran above) since
      # Dir.pwd is not reliable here.
      UI.message("Resolving workspace from project_root: #{project_root} (current Dir.pwd: #{Dir.pwd})")
      # Non-recursive glob (*) — only looks at ios/ top level so it finds
      # ios/AppRN.xcworkspace (CocoaPods-generated, contains Pods) and NOT
      # ios/AppRN.xcodeproj/project.xcworkspace (Xcode's internal self-workspace
      # that has no Pods integration). The old ** recursive glob returned both;
      # alphabetical sort put AppRN.xcodeproj/ before AppRN.xcworkspace/ so
      # .first always picked the wrong one, causing "Unable to open base
      # configuration reference file Pods-AppRN.release.xcconfig" at archive time.
      workspace_path = Dir[File.join(project_root, "ios", "*.xcworkspace")]
                          .reject { |p| p.include?("Pods") }.first
      if workspace_path.nil?
        UI.user_error!("No .xcworkspace found in ios/ — did expo prebuild succeed?\nFound: #{Dir[File.join(project_root, 'ios', '**', '*')].inspect}")
      end
      UI.message("Using workspace: #{workspace_path}")

      build_output_dir = File.join(project_root, "build")
      ipa_path = File.join(build_output_dir, "app.ipa")

      # expo prebuild generates the Xcode project with automatic signing but
      # no team set, so gym fails with "requires a development team". Set
      # the team explicitly; signing/profile management itself is then
      # handled non-interactively by xcodebuild via the ASC API key below
      # (-allowProvisioningUpdates + -authenticationKey*), not by match.
      xcodeproj_path = Dir[File.join(project_root, "ios", "*.xcodeproj")].first
      if xcodeproj_path.nil?
        UI.user_error!("No .xcodeproj found in ios/ — did expo prebuild succeed?\nFound: #{Dir[File.join(project_root, 'ios', '**', '*')].inspect}")
      end

      # Archiving always builds the Release configuration. The Expo/RN
      # template's project.pbxproj ships Release with CODE_SIGN_STYLE =
      # Automatic and a stale CODE_SIGN_IDENTITY = "iPhone Developer" baked
      # in. `match` above already auto-created/downloaded the exact
      # distribution cert + profile (no Apple Developer portal UI involved —
      # match does this via the ASC API key), so point Release at that
      # profile directly instead of asking Xcode to "automatically" resolve
      # one. Automatic signing + a manually forced "Apple Distribution"
      # identity is a contradiction Xcode refuses to build ("conflicting
      # provisioning settings") — automatic signing can only ever resolve a
      # Development identity for itself, never Distribution.
      # No `targets:` filter — applies to every target in the project. Fine
      # while the Expo template only ever generates a single app target; if a
      # generated app ever gains an extension target (notification service,
      # widget, etc.) this would force the same bundle_id/profile onto it too,
      # and would need a per-target profile_name lookup instead.
      profile_name = ENV["sigh_#{bundle_id}_appstore_profile-name"]
      if profile_name.nil? || profile_name.empty?
        # Log all sigh_* env vars to help diagnose a naming-format change.
        sigh_vars = ENV.select { |k, _| k.start_with?("sigh_") }
        UI.user_error!(
          "match did not set sigh_#{bundle_id}_appstore_profile-name.\n" \
          "Available sigh_* vars: #{sigh_vars.keys.inspect}\n" \
          "This usually means match ran but could not create/find the provisioning profile."
        )
      end
      update_code_signing_settings(
        use_automatic_signing: false,
        path: xcodeproj_path,
        team_id: ENV["APPLE_TEAM_ID"],
        bundle_identifier: bundle_id,
        code_sign_identity: "Apple Distribution",
        profile_name: profile_name,
        build_configurations: ["Release"],
      )

      # Known Expo/RN bug (expo/expo#44475, #44487, #44644), but NOT the
      # one-time-wipe-on-config-switch theory this codebase used to chase
      # (see git history) — three separate CI runs proved that wrong: a
      # correctly-executing priming archive (real compile time, not a
      # silently-failing no-op) still left the real `gym` archive hitting
      # the identical "module map file ... not found" errors for the same
      # 7 Expo modules every time. It's not a cache/wipe quirk; it's
      # deterministic.
      #
      # Root cause (confirmed via CocoaPods/CocoaPods#9266 and Callstack's
      # "Solving Swift Modular Header Issues in React Native for Good"):
      # this Podfile links pods as plain static *libraries* ("Framework
      # build type is static library" in the pod install log, i.e.
      # `use_frameworks!` is not set). Xcode only auto-synthesizes a real
      # `.modulemap` for a pod target when that pod is structured as a
      # *module* (framework-style, with an umbrella header) — flipping the
      # `DEFINES_MODULE` Xcode build setting via a post_install hook on a
      # plain static library does NOT make CocoaPods or Xcode actually
      # write that file; it just tells Xcode "look for one that nothing
      # ever generated", producing the exact "module map file ... not
      # found" errors seen here for EXConstants/ExpoAsset/ExpoFileSystem/
      # ExpoFont/ExpoKeepAwake/ExpoLinearGradient/ExpoModulesCore. Two
      # earlier attempts at a post_install DEFINES_MODULE hack (including
      # one that injected at the very end of Expo's own post_install block
      # to win any ordering race) both failed for this reason — it was
      # never an ordering problem, the file was simply never created.
      #
      # Fix: declare `use_frameworks! :linkage => :static` at the top of
      # the app's target block. This switches every pod (including the
      # Expo support pods) from plain static libraries to static
      # *frameworks*, which CocoaPods/Xcode build with proper module
      # structure (umbrella header + real .modulemap) automatically — the
      # officially-supported mechanism for this exact bug class, vs. the
      # private-API pre_install hacks tools like
      # callstack/cocoapods-swift-modular-headers resort to when frameworks
      # aren't an option.
      ios_dir = File.join(project_root, "ios")
      podfile_path = File.join(ios_dir, "Podfile")
      patch_marker = "use_frameworks! :linkage => :static"
      podfile_contents = File.read(podfile_path)

      # Strip any withExplicitModules post_install block left by the old server-side
      # plugin. The use_frameworks! patch below supersedes it entirely, and leaving
      # it in causes CocoaPods to error: "Specifying multiple post_install hooks
      # is unsupported" because Expo's react_native_post_install already adds one.
      # The old regex matched on an exact comment string ("# [withExplicitModules]
      # already applied") which would silently fail to strip the block if that
      # comment was ever edited, leaving a duplicate post_install block that makes
      # CocoaPods abort with "Specifying multiple post_install hooks is unsupported".
      # Broadened to match any post_install block that contains "withExplicitModules"
      # anywhere inside its body (multiline, non-greedy).
      if podfile_contents.include?("withExplicitModules")
        podfile_contents = podfile_contents.gsub(
          /\n*^post_install do \|installer\|\n.*?withExplicitModules.*?\n^end\n?/m,
          ""
        )
        File.write(podfile_path, podfile_contents)
        UI.message("Removed legacy withExplicitModules post_install block from Podfile")
      end
      # Always strip any existing use_frameworks! / use_modular_headers! lines
      # and re-inject unconditionally. The old `unless` guard silently skipped
      # injection whenever the Podfile on disk already contained use_frameworks!
      # (e.g. left by a prior run that didn't run expo prebuild --clean, or
      # injected in the wrong scope/args by use_expo_modules!'s pre_install hook
      # evaluated at a previous pod install). Skipping left pods building as
      # plain static *libraries* ("Framework build type is static library"),
      # producing no .modulemap files in BuildProductsPath — the exact "module
      # map file not found" compile error seen for all Expo pods.
      # use_frameworks! :linkage => :static is mutually exclusive with
      # use_modular_headers! — strip both before injecting.
      original_contents = podfile_contents.dup
      work_contents = podfile_contents.gsub(/^[[:space:]]*use_frameworks!.*\n/, "")
      work_contents = work_contents.gsub(/^[[:space:]]*use_modular_headers![[:space:]]*\n/, "")
      UI.message("Stripped pre-existing use_frameworks!/use_modular_headers! line(s) before re-injecting") if work_contents != original_contents

      target_re = /^(\s*)target\s+['"][^'"]+['"]\s+do\s*\n/
      start_match = target_re.match(work_contents)
      UI.user_error!("Could not find an app `target '...' do` block in #{podfile_path} to patch") if start_match.nil?

      indent = start_match[1] + "  "
      injection = "#{indent}# --- ios-certs CI patch: force static frameworks for proper modulemaps ---\n#{indent}#{patch_marker}\n"
      insert_at = start_match.end(0)
      final_contents = work_contents[0...insert_at] + injection + work_contents[insert_at..]

      # Inject SWIFT/CLANG_ENABLE_EXPLICIT_MODULES=NO into the existing post_install
      # block so CocoaPods writes these settings into Pods.xcodeproj at pod-install
      # time — the most reliable path, independent of the xcodeproj gem (which runs
      # after pod install and can have format compatibility issues with Xcode 16
      # project files) and xcargs (which only reach the top-level xcodebuild call,
      # not the swift-frontend sub-processes that do actual Swift compilation).
      # Without this, Xcode 16.3's module pre-scanner runs before ExpoModulesCore
      # is compiled and reports "no such module 'ExpoModulesCore'" even though
      # use_frameworks! :linkage => :static correctly builds it as a framework.
      explicit_modules_snippet = \
        "  # --- ios-certs CI: disable Xcode 16.3 explicit module pre-scanning ---\n" \
        "  installer.pods_project.targets.each do |t|\n" \
        "    t.build_configurations.each do |c|\n" \
        "      c.build_settings['SWIFT_ENABLE_EXPLICIT_MODULES'] = 'NO'\n" \
        "      c.build_settings['CLANG_ENABLE_EXPLICIT_MODULES'] = 'NO'\n" \
        "    end\n" \
        "  end\n"
      if final_contents.match?(/^post_install do \|installer\|/m)
        # Non-greedy .*? with /m reaches the first ^end at column 0 — always the
        # post_install block's own closing end in the Expo SDK 51 template because
        # react_native_post_install uses parentheses (no nested do..end inside).
        final_contents = final_contents.sub(
          /^(post_install do \|installer\|.*?)(^end\n?)/m,
          "\\1#{explicit_modules_snippet}\\2"
        )
        UI.message("Injected SWIFT/CLANG_ENABLE_EXPLICIT_MODULES=NO into existing post_install block")
      else
        final_contents += "\npost_install do |installer|\n#{explicit_modules_snippet}end\n"
        UI.message("No existing post_install block — added one with SWIFT/CLANG_ENABLE_EXPLICIT_MODULES=NO")
      end

      File.write(podfile_path, final_contents)
      UI.message("Patched Podfile: added `#{patch_marker}` so pods build as proper modules with real modulemaps")

      # Diagnostic: confirm use_frameworks! injection count — if 0 the target
      # regex failed silently and pods will build as plain static libraries,
      # causing "no such module 'ExpoModulesCore'" at archive time.
      injection_count = final_contents.scan("use_frameworks! :linkage => :static").length
      UI.message("use_frameworks! :linkage => :static count in Podfile: #{injection_count}")
      UI.user_error!("Podfile patch failed — target block regex did not match in #{podfile_path}") if injection_count == 0

      Dir.chdir(ios_dir) do
        sh("bundle exec pod install 2>&1 | tee /tmp/pod_install.log")
        # Confirm whether pods built as frameworks (good) or static libraries (bad).
        # "Framework build type is a static framework" = use_frameworks! worked.
        # "Framework build type is static library"    = use_frameworks! NOT applied.
        sh("grep -m3 'Framework build type' /tmp/pod_install.log || echo 'Framework build type line not found in pod install log'")
      end

      # Bake CLANG_ENABLE_EXPLICIT_MODULES=NO and SWIFT_ENABLE_EXPLICIT_MODULES=NO
      # into both AppRN.xcodeproj and Pods.xcodeproj at every build configuration.
      #
      # Why xcargs alone is insufficient on Xcode 16.3:
      # The PrecompileSwiftBridgingHeader phase reads build settings directly
      # from the project file before xcargs are applied to that sub-step, so
      # passing these as xcargs to gym has no effect on bridging header
      # precompilation. Baking the setting into the project files ensures every
      # phase (including PrecompileSwiftBridgingHeader) sees NO unconditionally.
      require 'xcodeproj'
      [
        xcodeproj_path,
        File.join(ios_dir, "Pods", "Pods.xcodeproj"),
      ].each do |proj_path|
        next unless File.exist?(proj_path)
        proj = Xcodeproj::Project.open(proj_path)
        proj.targets.each do |target|
          target.build_configurations.each do |config|
            config.build_settings["CLANG_ENABLE_EXPLICIT_MODULES"] = "NO"
            config.build_settings["SWIFT_ENABLE_EXPLICIT_MODULES"] = "NO"
          end
        end
        proj.build_configurations.each do |config|
          config.build_settings["CLANG_ENABLE_EXPLICIT_MODULES"] = "NO"
          config.build_settings["SWIFT_ENABLE_EXPLICIT_MODULES"] = "NO"
        end
        proj.save
        UI.message("Baked CLANG/SWIFT_ENABLE_EXPLICIT_MODULES=NO into #{File.basename(proj_path)}")
      end

      gym(
        scheme: scheme,
        workspace: workspace_path,
        configuration: "Release",
        export_method: "app-store",
        output_directory: build_output_dir,
        output_name: "app.ipa",
        clean: true,
        # Xcode 16+ enables "Explicitly Built Modules" by default for Clang
        # (C/ObjC), which causes clang to resolve CocoaPods .modulemap files
        # (EXConstants, ExpoModulesCore, etc.) before their targets are
        # compiled — they don't exist yet in DerivedData, producing "module
        # map file not found" archive failures. CLANG_ENABLE_EXPLICIT_MODULES
        # is the real setting (NOT "ENABLE_EXPLICIT_MODULES_SUPPORT" — that
        # key doesn't exist in Xcode and was silently ignored, which is why
        # archives kept failing even with that xcarg set).
        #
        # Xcode 26 separately turned the same thing on for Swift, default-on
        # for all Swift targets — manifests as "Bridging header dependency
        # scan failure: fatal error: module map file ... not found" instead
        # (Swift's own explicit-module dependency scanner hitting the same
        # not-yet-built modulemap). Needs its own, different opt-out:
        # SWIFT_ENABLE_EXPLICIT_MODULES=NO. Disabling both restores the
        # pre-Xcode-16 build order where pod targets are fully compiled
        # before the app target scans their module maps.
        xcargs: "CLANG_ENABLE_EXPLICIT_MODULES=NO SWIFT_ENABLE_EXPLICIT_MODULES=NO",
        export_options: {
          method: "app-store",
          teamID: ENV["APPLE_TEAM_ID"],
          signingStyle: "manual",
          provisioningProfiles: {
            bundle_id => profile_name,
          },
        },
      )

      upload_to_testflight(
        api_key: api_key,
        ipa: ipa_path,
        app_identifier: bundle_id,
        skip_waiting_for_build_processing: true,
        notify_external_testers: false,
      )
    ensure
      # Restore the default keychain search list before deleting the custom one,
      # otherwise macOS can be left with a broken/empty search list.
      login_keychain = File.expand_path("~/Library/Keychains/login.keychain-db")
      sh("security list-keychains -d user -s '#{login_keychain}'") rescue nil
      delete_keychain(name: ENV["MATCH_KEYCHAIN_NAME"]) rescue nil
    end
  end

  desc "One-time: generate and push certs + profiles to the certificates repo"
  lane :init_match do
    cert_type = (ENV["MATCH_TYPE"] || "appstore").gsub("-", "")

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_CONNECT_KEY_FILEPATH"],
      in_house: false,
    )

    # Revoke all existing certs of this type in the portal and wipe them from
    # the git repo so match can create a fresh certificate without hitting
    # Apple's 2-cert limit. Safe here because init_match is an explicit reset.
    match_nuke(
      type: cert_type,
      api_key: api_key,
      git_url: ENV["MATCH_GIT_URL"],
      git_basic_authorization: ENV["MATCH_GIT_PAT_B64"],
      team_id: ENV["APPLE_TEAM_ID"],
      skip_confirmation: true,
    )

    # Empty array + skip_provisioning_profiles = certificate only.
    # No bundle ID lookup is performed; profiles are created per-app in build_ipa.
    match(
      type: cert_type,
      readonly: false,
      api_key: api_key,
      git_url: ENV["MATCH_GIT_URL"],
      git_basic_authorization: ENV["MATCH_GIT_PAT_B64"],
      app_identifier: [],
      team_id: ENV["APPLE_TEAM_ID"],
      skip_provisioning_profiles: true,
    )
  end
end
