require 'digest'

default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight. Bundle ID and scheme are auto-derived per app."
  lane :build_ipa do
    # Fastlane itself runs with Dir.pwd set to this Fastfile's own directory
    # (.../project/fastlane), not the project root (.../project) — confirmed
    # by logging Dir.pwd here. So "ios/" must be resolved one level up.
    project_root = File.expand_path("..", Dir.pwd)

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_CONNECT_KEY_FILEPATH"],
      in_house: false,
    )

    bundle_id = ENV["APP_BUNDLE_ID"]
    scheme    = ENV["XCODE_SCHEME"]

    UI.message("Building bundle ID : #{bundle_id}")
    UI.message("Xcode scheme       : #{scheme}")

    # Bundle ID registration is handled by the CI workflow step before
    # Fastlane runs — no Spaceship token setup here so match's api_key auth
    # is not overridden by a conflicting global Spaceship token.

    # The self-hosted runner's disk persists between jobs (unlike GitHub-hosted
    # macos-latest), so a keychain from a previous/crashed run can still be on
    # the keychain search list and collide with create_keychain below.
    delete_keychain(name: ENV["MATCH_KEYCHAIN_NAME"]) if File.exist?(File.expand_path("~/Library/Keychains/#{ENV["MATCH_KEYCHAIN_NAME"]}-db"))

    create_keychain(
      name: ENV["MATCH_KEYCHAIN_NAME"],
      password: ENV["MATCH_KEYCHAIN_PASSWORD"],
      default_keychain: true,
      unlock: true,
      timeout: 3600,
      lock_when_sleeps: false,
    )

    begin
      # Look up whether an App Store Connect app record already exists for
      # this bundle ID — e.g. a previous run got this far and created it
      # before failing later in the pipeline. This lookup works with the
      # API key (only POST /v1/apps for *creating* an app is blocked for
      # standard accounts, GET is not), so it never needs Apple ID web auth.
      # Skipping produce when the app already exists also means a re-run of
      # an already-provisioned app no longer depends on a valid Apple ID
      # session/2FA at all.
      existing_app = Spaceship::ConnectAPI::App.find(bundle_id)

      if existing_app
        UI.message("App Store Connect app already exists for #{bundle_id} (id: #{existing_app.id}) — skipping produce.")
      else
        # produce uses Apple ID + app-specific password (Spaceship web auth)
        # because the ASC REST API forbids POST /v1/apps for standard accounts.
        #
        # App Store *display names* are unique across ALL Apple developer
        # accounts worldwide (unlike bundle IDs, which are effectively
        # namespaced here by the "com.frontendx." prefix) — generic generated
        # names like "Todo App" or "Weather App" routinely collide with an
        # existing app from a different account. Append a short suffix
        # derived from the bundle ID to dodge that, deterministically (not
        # random) so retrying produce for the same bundle ID keeps producing
        # the same name instead of registering a new one each attempt.
        name_suffix = Digest::SHA256.hexdigest(bundle_id)[0, 6]
        base_name = bundle_id.split('.').last.gsub('-', ' ').split.map(&:capitalize).join(' ')[0, 22]
        safe_display_name = "#{base_name} #{name_suffix}"[0, 30]
        sku = bundle_id.gsub('.', '-')[0, 50]
        produce(
          username:       ENV["APPLE_ID"],
          app_identifier: bundle_id,
          app_name:       safe_display_name,
          company_name:   ENV["APPLE_COMPANY_NAME"],
          language:       "English",
          app_version:    "1.0",
          sku:            sku,
          team_id:        ENV["APPLE_TEAM_ID"],
          itc_team_id:    ENV["APPLE_TEAM_ID"],
        )
      end

      # appstore type: no device registration required in the portal.
      # development type was failing with ENTITY_ERROR_RELATIONSHIP_REQUIRED
      # because Apple requires at least one registered device for dev profiles.
      match(
        type: "appstore",
        readonly: false,
        api_key: api_key,
        git_url: ENV["MATCH_GIT_URL"],
        git_basic_authorization: ENV["MATCH_GIT_PAT_B64"],
        app_identifier: bundle_id,
        team_id: ENV["APPLE_TEAM_ID"],
        keychain_name: ENV["MATCH_KEYCHAIN_NAME"],
        keychain_password: ENV["MATCH_KEYCHAIN_PASSWORD"],
      )

      # Resolve the .xcworkspace path — handles app names with spaces safely.
      # Anchored to project_root (captured before any actions ran above) since
      # Dir.pwd is not reliable here.
      UI.message("Resolving workspace from project_root: #{project_root} (current Dir.pwd: #{Dir.pwd})")
      workspace_path = Dir[File.join(project_root, "ios", "**", "*.xcworkspace")]
                          .reject { |p| p.include?("Pods") }.first
      if workspace_path.nil?
        UI.user_error!("No .xcworkspace found in ios/ — did expo prebuild succeed?\nFound: #{Dir[File.join(project_root, 'ios', '**', '*')].inspect}")
      end
      UI.message("Using workspace: #{workspace_path}")

      build_output_dir = File.join(project_root, "build")
      ipa_path = File.join(build_output_dir, "app.ipa")

      # expo prebuild generates the Xcode project with automatic signing but
      # no team set, so gym fails with "requires a development team". Set
      # the team explicitly; signing/profile management itself is then
      # handled non-interactively by xcodebuild via the ASC API key below
      # (-allowProvisioningUpdates + -authenticationKey*), not by match.
      xcodeproj_path = Dir[File.join(project_root, "ios", "*.xcodeproj")].first
      if xcodeproj_path.nil?
        UI.user_error!("No .xcodeproj found in ios/ — did expo prebuild succeed?\nFound: #{Dir[File.join(project_root, 'ios', '**', '*')].inspect}")
      end

      # Archiving always builds the Release configuration. The Expo/RN
      # template's project.pbxproj ships Release with CODE_SIGN_STYLE =
      # Automatic and a stale CODE_SIGN_IDENTITY = "iPhone Developer" baked
      # in. `match` above already auto-created/downloaded the exact
      # distribution cert + profile (no Apple Developer portal UI involved —
      # match does this via the ASC API key), so point Release at that
      # profile directly instead of asking Xcode to "automatically" resolve
      # one. Automatic signing + a manually forced "Apple Distribution"
      # identity is a contradiction Xcode refuses to build ("conflicting
      # provisioning settings") — automatic signing can only ever resolve a
      # Development identity for itself, never Distribution.
      profile_name = ENV["sigh_#{bundle_id}_appstore_profile-name"]
      update_code_signing_settings(
        use_automatic_signing: false,
        path: xcodeproj_path,
        team_id: ENV["APPLE_TEAM_ID"],
        bundle_identifier: bundle_id,
        code_sign_identity: "Apple Distribution",
        profile_name: profile_name,
        build_configurations: ["Release"],
      )

      # Known Expo/RN bug (expo/expo#44475, #44487, #44644): the RN
      # "replace-rncore-version.js" :before_compile script phase wipes and
      # regenerates a shared Pods directory whenever it detects a Debug/
      # Release "configuration switch" — and on a brand-new CI runner, the
      # very first build is *always* such a switch (no prior cached config
      # to compare against), destroying the static-framework modulemaps
      # (EXConstants, ExpoModulesCore, etc.) that `pod install` just
      # generated. That's why this only ever fails on `archive`, never on a
      # second build with the same configuration.
      #
      # Work around it by priming that one-time wipe with a throwaway build
      # (allowed to fail — the wipe script runs early, before the failure
      # point, so it still does its job), then re-running `pod install` to
      # regenerate the modulemaps it just destroyed. The real archive below
      # is then a same-configuration rebuild, so the wipe script is a no-op
      # and the freshly-regenerated modulemaps survive intact.
      UI.message("Priming Release build once to trigger Expo/RN's one-time modulemap wipe...")
      ios_dir = File.join(project_root, "ios")
      Dir.chdir(ios_dir) do
        system(
          "xcodebuild -workspace '#{File.basename(workspace_path)}' -scheme '#{scheme}' " \
          "-configuration Release -destination 'generic/platform=iOS' build " \
          "> /tmp/priming_build.log 2>&1"
        )
      end
      UI.message("Priming build finished (failure here is expected) — regenerating modulemaps via pod install...")
      Dir.chdir(ios_dir) do
        sh("bundle exec pod install 2>&1")
      end

      gym(
        scheme: scheme,
        workspace: workspace_path,
        configuration: "Release",
        export_method: "app-store",
        output_directory: build_output_dir,
        output_name: "app.ipa",
        clean: true,
        # Xcode 26+ enables "Explicitly Built Modules" by default, which causes
        # clang to resolve CocoaPods .modulemap files (EXConstants, ExpoModulesCore,
        # etc.) before their targets are compiled — they don't exist yet in
        # DerivedData, producing "module map file not found" archive failures.
        # Disabling it restores the Xcode 15/16 build order where pod targets are
        # compiled before the app target scans their module maps.
        xcargs: "ENABLE_EXPLICIT_MODULES_SUPPORT=NO",
        export_options: {
          method: "app-store",
          teamID: ENV["APPLE_TEAM_ID"],
          signingStyle: "manual",
          provisioningProfiles: {
            bundle_id => profile_name,
          },
        },
      )

      upload_to_testflight(
        api_key: api_key,
        ipa: ipa_path,
        app_identifier: bundle_id,
        skip_waiting_for_build_processing: true,
        notify_external_testers: false,
      )
    ensure
      delete_keychain(name: ENV["MATCH_KEYCHAIN_NAME"]) rescue nil
    end
  end

  desc "One-time: generate and push certs + profiles to the certificates repo"
  lane :init_match do
    cert_type = (ENV["MATCH_TYPE"] || "appstore").gsub("-", "")

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_CONNECT_KEY_FILEPATH"],
      in_house: false,
    )

    # Revoke all existing certs of this type in the portal and wipe them from
    # the git repo so match can create a fresh certificate without hitting
    # Apple's 2-cert limit. Safe here because init_match is an explicit reset.
    match_nuke(
      type: cert_type,
      api_key: api_key,
      git_url: ENV["MATCH_GIT_URL"],
      git_basic_authorization: ENV["MATCH_GIT_PAT_B64"],
      team_id: ENV["APPLE_TEAM_ID"],
      skip_confirmation: true,
    )

    # Empty array + skip_provisioning_profiles = certificate only.
    # No bundle ID lookup is performed; profiles are created per-app in build_ipa.
    match(
      type: cert_type,
      readonly: false,
      api_key: api_key,
      git_url: ENV["MATCH_GIT_URL"],
      git_basic_authorization: ENV["MATCH_GIT_PAT_B64"],
      app_identifier: [],
      team_id: ENV["APPLE_TEAM_ID"],
      skip_provisioning_profiles: true,
    )
  end
end
