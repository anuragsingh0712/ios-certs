default_platform(:ios)

platform :ios do
  desc "Build a real device-installable .ipa. Bundle ID and scheme are auto-derived per app."
  lane :build_ipa do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_CONNECT_KEY_FILEPATH"],
      in_house: false,
    )

    bundle_id = ENV["APP_BUNDLE_ID"]
    scheme    = ENV["XCODE_SCHEME"]

    UI.message("Building bundle ID : #{bundle_id}")
    UI.message("Xcode scheme       : #{scheme}")

    # Register the bundle ID via Spaceship (produce doesn't support API key auth
    # in this fastlane version). Spaceship uses the token set by
    # app_store_connect_api_key above — no username/password needed.
    require 'spaceship'
    token = Spaceship::ConnectAPI::Token.create(
      key_id:    ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      filepath:  ENV["APP_STORE_CONNECT_KEY_FILEPATH"],
    )
    Spaceship::ConnectAPI.token = token

    existing = Spaceship::ConnectAPI::BundleId.find(bundle_id)
    if existing
      UI.message("Bundle ID already registered: #{bundle_id}")
    else
      # ASC rejects underscores/special chars in the display name — sanitize to alphanumeric + spaces
      safe_name = scheme.gsub(/[^a-zA-Z0-9 ]/, ' ').squeeze(' ').strip
      Spaceship::ConnectAPI::BundleId.create(
        identifier: bundle_id,
        name:       safe_name,
        platform:   "IOS",
      )
      UI.success("Registered bundle ID: #{bundle_id} (name: #{safe_name})")
    end

    create_keychain(
      name: ENV["MATCH_KEYCHAIN_NAME"],
      password: ENV["MATCH_KEYCHAIN_PASSWORD"],
      default_keychain: true,
      unlock: true,
      timeout: 3600,
      lock_when_sleeps: false,
    )

    # readonly: false lets Match auto-register new bundle IDs and
    # generate provisioning profiles for them in App Store Connect.
    match(
      type: "development",
      readonly: false,
      api_key: api_key,
      git_url: ENV["MATCH_GIT_URL"],
      git_basic_authorization: ENV["MATCH_GIT_PAT_B64"],
      app_identifier: bundle_id,
      team_id: ENV["APPLE_TEAM_ID"],
      keychain_name: ENV["MATCH_KEYCHAIN_NAME"],
      keychain_password: ENV["MATCH_KEYCHAIN_PASSWORD"],
      generate_apple_certs: false,
    )

    # Resolve the .xcworkspace path — handles app names with spaces safely
    workspace_path = Dir["ios/*.xcworkspace"].first
    if workspace_path.nil?
      UI.user_error!("No .xcworkspace found in ios/ — did expo prebuild succeed?")
    end
    UI.message("Using workspace: #{workspace_path}")

    gym(
      scheme: scheme,
      workspace: workspace_path,
      export_method: "development",
      output_directory: "./build",
      output_name: "app.ipa",
      clean: true,
      xcargs: "-allowProvisioningUpdates",
      export_options: {
        method: "development",
        teamID: ENV["APPLE_TEAM_ID"],
      },
    )

    delete_keychain(name: ENV["MATCH_KEYCHAIN_NAME"])
  end

  desc "One-time: generate and push certs + profiles to the certificates repo"
  lane :init_match do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_CONNECT_KEY_FILEPATH"],
      in_house: false,
    )

    # Empty array + skip_provisioning_profiles = certificate only.
    # No bundle ID lookup is performed; profiles are created per-app in build_ipa.
    match(
      type: (ENV["MATCH_TYPE"] || "adhoc").gsub("-", ""),
      readonly: false,
      api_key: api_key,
      git_url: ENV["MATCH_GIT_URL"],
      git_basic_authorization: ENV["MATCH_GIT_PAT_B64"],
      app_identifier: [],
      team_id: ENV["APPLE_TEAM_ID"],
      skip_provisioning_profiles: true,
    )
  end
end
